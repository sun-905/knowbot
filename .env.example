# MySQL
DATABASE_URL=mysql+aiomysql://root:root123@localhost:3306/cs_bot

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# LLM (DeepSeek) — 请填入你的 API Key
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# LLM Backup (Qwen) — 可选
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Embedding
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DEVICE=cuda

# App
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
DAILY_QUOTA_LIMIT=100
MAX_QUESTION_LENGTH=500
MAX_CONTEXT_ROUNDS=5
RETRIEVAL_TOP_K=5
RETRIEVAL_TOP_K_FLOOR=0
RETRIEVAL_TOP_K_OPT=0
RETRIEVAL_THRESHOLD=0.43
INTENT_CLARIFY_THRESHOLD=0.7
RETRIEVAL_COARSE_K=20

# 查询改写
QUERY_REWRITE_ENABLED=true
QUERY_REWRITE_TIMEOUT=5.0
QUERY_REWRITE_MODEL=deepseek-chat
