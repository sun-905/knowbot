{
  "rules": [
    {
      "intent": "其他",
      "priority": 99,
      "keywords": ["吗", "呢", "吧"],
      "patterns": ["(什么|哪些|多少|怎么|如何|怎样|为什么|为何|能不能|可以).{0,10}(吗|呢|？|$)", ".*(是什么|有哪些|怎么做|怎么办|要注意什么|需要注意什么|怎么避免|如何避免)"]
    },
    {
      "intent": "闲聊",
      "priority": 10,
      "keywords": ["你好", "嗨", "hello", "hi", "早", "晚上好", "下午好", "你是谁", "你叫什么", "你几岁", "你是机器人吗", "冷笑话", "笑话", "讲个故事", "聊天", "今天是什么日子", "今天几号", "今天星期几", "今天日期", "谢谢", "感谢", "再见", "bye", "晚安"],
      "patterns": ["^(你好|嗨|hello|hi|早|晚上好|下午好)", "(你是谁|你叫什么|你的名字)", "讲个?(笑话|故事|冷笑话)", "今天(是|的)?(什么日子|几号|星期几|日期)", "(谢谢|感谢|多谢)", "(再见|bye|拜拜|晚安)"]
    },
    {
      "intent": "投诉",
      "priority": 20,
      "keywords": ["投诉", "举报", "差评", "不满"],
      "patterns": ["我要投诉", "我要举报"]
    },
    {
      "intent": "售后问题",
      "priority": 30,
      "keywords": ["退货", "退款", "换货", "维修", "保修", "售后"],
      "patterns": ["(怎么|如何|想|要)(退货|退款|换货|维修)", "售后(怎么|如何|在哪)"]
    },
    {
      "intent": "订单查询",
      "priority": 30,
      "keywords": ["订单", "物流", "快递", "发货", "到哪"],
      "patterns": ["(查|我的|看看)订单", "(怎么|还没|何时)(发货|到)", "物流(信息|追踪|到哪)"]
    },
    {
      "intent": "产品咨询",
      "priority": 40,
      "keywords": ["多少钱", "价格", "优惠", "折扣", "功能", "参数", "配置"],
      "patterns": ["(多少|什么)价(格|钱)", "(有|什么)优惠"]
    }
  ]
}
